# ============================================
# AniStream — Configuration des API
# ============================================
# Copiez ce fichier en `.env` puis remplissez vos propres valeurs.
# ⚠️ IMPORTANT : l'app est en HTML/JS pur (aucun build), le navigateur
# ne peut PAS lire `.env` directement. Les valeurs ci-dessous doivent
# être recopiées dans `public/config.js` (voir ce fichier), qui est
# chargé par `public/app.html`.
#
# Gardez `.env` en local — il est ignoré par git via `.gitignore`.
# ============================================

# --- Jikan (MyAnimeList) : catalogue & personnages ---
# API publique sans clé. Vous pouvez pointer vers un proxy/mirror
# si l'API officielle renvoie des 504.
JIKAN_BASE_URL=https://api.jikan.moe/v4

# --- Waifu.pics : images bonus ---
WAIFU_BASE_URL=https://api.waifu.pics/sfw/waifu

# --- AnimeChan : citations d'anime (optionnel) ---
ANIMECHAN_BASE_URL=https://animechan.io/api/v1

# --- Clé API personnelle (si vous utilisez un proxy authentifié) ---
# Laisser vide si aucune clé n'est requise.
ANIME_API_KEY=
